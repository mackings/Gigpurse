# MongoDB connection string (local Docker or a hosted cluster, e.g. MongoDB
# Atlas). Falls back to mongodb://localhost:27017 if unset.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?appName=Cluster0
MONGODB_DB=gigpurse_dev

# Signs auth JWTs. Use a real random secret outside local dev.
JWT_SECRET=dev-secret-for-local-e2e

# Email delivery (optional — signup/reset emails just log to the server
# outbox if none of these are configured). Pick one provider.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Web Push (optional — generate with webpush.GenerateVAPIDKeys(), see
# docs/API.md's Web Push section). Push notifications are a no-op if unset.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@gigpurse.app

# Self-signup gates for elevated roles (both default closed).
ALLOW_ADMIN_SIGNUP=false
ALLOW_MODERATOR_SIGNUP=false

            "body": {
              "mode": "raw",
              "raw": "{\n  \"recv_id\": \"{{musician_id}}\",\n  \"content\": \"Can we talk on WhatsApp or pay by Paypal?\"\n}"
            },
            "url": "{{base_url}}/chats",
            "description": "Sends a chat message and filters external payment/contact words."
          }
        },
        {
          "name": "Chat History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",

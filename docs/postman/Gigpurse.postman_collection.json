          "name": "My Musician Jobs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{musician_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/jobs/mine?status=active",
            "description": "Lists musician jobs by pending, active, or completed status."
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send REST Chat",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"

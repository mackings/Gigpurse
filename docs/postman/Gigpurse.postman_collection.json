{
  "info": {
    "name": "Gigpurse Backend API",
    "description": "Role-structured Gigpurse API collection. Select the environment, run signup, copy the six-digit code from email/server logs into the *_email_code variables, verify email, then login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://gigpurse-server.onrender.com"
    }
  ],
  "item": [
    {
      "name": "Public APIs",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/",
            "description": "Service health check."
          }
        },
        {
          "name": "Browse Musicians",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/musicians?genre=Afrobeats&instrument=Guitar&location=Lagos&min_exp=3&sort_by=experience",
            "description": ""
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/jobs?status=open&genre=Afrobeats&sort_by=budget&max_applications=5",
            "description": ""
          }
        },
        {
          "name": "Get Job By ID",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/jobs?id={{job_id}}",
            "description": ""
          }
        },
        {
          "name": "List Reviews",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/reviews?user_id={{musician_id}}",
            "description": ""
          }
        },
        {
          "name": "Average Rating",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/reviews/average?user_id={{musician_id}}",
            "description": ""
          }
        }
      ]
    },
    {
      "name": "Auth - Client",
      "item": [
        {
          "name": "Signup Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data.id) pm.environment.set('client_id', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"client\",\n  \"name\": \"Demo Client\"\n}"
            },
            "url": "{{base_url}}/auth/signup",
            "description": "Creates client and sends a 6-digit email verification code."
          }
        },
        {
          "name": "Resend Client Email Code",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\"\n}"
            },
            "url": "{{base_url}}/auth/email-verification/resend",
            "description": ""
          }
        },
        {
          "name": "Verify Client Email",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"code\": \"{{client_email_code}}\"\n}"
            },
            "url": "{{base_url}}/auth/email-verification/confirm",
            "description": ""
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) { pm.environment.set('client_token', json.data.token); pm.environment.set('token', json.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": ""
          }
        },
        {
          "name": "Request Client Password Reset",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\"\n}"
            },
            "url": "{{base_url}}/auth/password-reset/request",
            "description": ""
          }
        },
        {
          "name": "Confirm Client Password Reset",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"paste-token-from-email-or-server-log\",\n  \"new_password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/password-reset/confirm",
            "description": ""
          }
        }
      ]
    },

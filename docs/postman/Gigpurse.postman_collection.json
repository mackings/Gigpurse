            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/contracts?id={{contract_id}}",
            "description": "Fetches a contract by ID. User must be participant or admin."
          }
        },
        {
          "name": "Create Direct Hire",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('direct_hire_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"musician_id\": \"{{musician_id}}\",\n  \"title\": \"Private acoustic set\",\n  \"description\": \"Direct hire for a private event\",\n  \"price\": 300\n}"
            },
            "url": "{{base_url}}/direct-hires",
            "description": "Client creates a direct hire request."
          }
        },
        {
          "name": "List Direct Hires",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{musician_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/direct-hires?status=pending",
            "description": "Lists direct hire requests for the authenticated user."
          }
        },
        {
          "name": "Respond To Direct Hire",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{musician_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": \"{{direct_hire_id}}\",\n  \"decision\": \"accepted\"\n}"
            },
            "url": "{{base_url}}/direct-hires/respond",
            "description": "Musician accepts or declines a direct hire request."
          }
        },
        {
          "name": "Complete Contract",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }

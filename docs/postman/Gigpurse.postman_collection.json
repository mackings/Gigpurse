              "raw": "{\n  \"job_id\": \"{{job_id}}\",\n  \"proposal\": \"I can deliver a clean session.\",\n  \"price_bid\": 450\n}"
            },
            "url": "{{base_url}}/jobs/apply",
            "description": "Musician applies for an open job."
          }
        },
        {
          "name": "List Applications For Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",

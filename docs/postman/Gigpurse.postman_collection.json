              "bearer": [
                {
                  "key": "token",
                  "value": "{{musician_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/jobs/recommended?limit=5",
            "description": "Returns personalized open gigs for a musician."
          }

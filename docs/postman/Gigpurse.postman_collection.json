                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/chats/history?user_id={{musician_id}}",
            "description": "Returns chat history with another user."
          }
        },
        {
          "name": "Recent Chats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/chats/recent",
            "description": "Returns latest message per chat partner."
          }
        },
        {
          "name": "WebSocket Chat URL",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/chats/ws?token={{client_token}}",
            "description": "Use Postman's WebSocket client with ws://localhost:8080/chats/ws?token={{client_token}} and send {\"recv_id\":\"{{musician_id}}\",\"content\":\"Realtime hello\"}."
          }
        }
      ]
    },
    {
      "name": "Contracts And Direct Hire",
      "item": [
        {
          "name": "List Contracts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length) pm.environment.set('contract_id', json[0].id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/contracts",
            "description": "Lists authenticated user's contracts."
          }
        },
        {
          "name": "Get Contract By ID",

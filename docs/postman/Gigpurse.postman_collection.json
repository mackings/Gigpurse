            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contract_id\": \"{{contract_id}}\"\n}"
            },
            "url": "{{base_url}}/contracts/complete",
            "description": "Client marks a contract completed."
          }
        }
      ]

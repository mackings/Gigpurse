{
  "info": {
    "name": "Gigpurse Backend API",
    "description": "Gigpurse backend API collection generated from docs/API.md. Import this into Postman, select the Gigpurse Local environment, run signup/login requests to populate tokens and IDs, then publish documentation from the collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/",
            "description": "Checks whether the API is online."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('client_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"client\",\n  \"name\": \"Demo Client\"\n}"
            },
            "url": "{{base_url}}/auth/signup",
            "description": "Creates a dummy client account. Status codes: 201, 400, 405, 500."
          }
        },
        {
          "name": "Signup Musician",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('musician_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"musician@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"musician\",\n  \"name\": \"Demo Musician\"\n}"
            },
            "url": "{{base_url}}/auth/signup",
            "description": "Creates a dummy musician account."
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('client_token', json.token);",
                  "pm.environment.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Logs in the client and stores client_token."
          }
        },
        {
          "name": "Login Musician",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('musician_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"musician@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Logs in the musician and stores musician_token."
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\"\n}"
            },
            "url": "{{base_url}}/auth/password-reset/request",
            "description": "Requests a password reset. Current implementation logs the token to the server email outbox."
          }
        },
        {
          "name": "Confirm Password Reset",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"paste-token-from-server-log\",\n  \"new_password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/password-reset/confirm",
            "description": "Confirms a password reset with a valid token."
          }
        }
      ]
    },
    {
      "name": "Profiles And Search",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/profile",
            "description": "Returns the authenticated user's profile. Set {{token}} to client_token or musician_token."
          }
        },
        {
          "name": "Update Client Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Client\",\n  \"bio\": \"Looking for reliable session musicians\",\n  \"location\": \"Lagos\",\n  \"client_profile\": {\n    \"company_name\": \"Gigpurse Events\"\n  }\n}"
            },
            "url": "{{base_url}}/users/profile",
            "description": "Updates the client profile."
          }
        },
        {
          "name": "Update Musician Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{musician_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Musician\",\n  \"bio\": \"Guitarist and producer\",\n  \"location\": \"Lagos\",\n  \"musician_profile\": {\n    \"stage_name\": \"Demo Strings\",\n    \"instrument\": \"Guitar\",\n    \"genre\": \"Afrobeats\",\n    \"experience_years\": 7,\n    \"portfolio\": [\n      {\n        \"title\": \"Live Session\",\n        \"description\": \"Recorded guitar session\",\n        \"url\": \"https://example.com/session.mp4\"\n      }\n    ]\n  }\n}"
            },
            "url": "{{base_url}}/users/profile",
            "description": "Updates the musician profile."
          }
        },
        {
          "name": "Browse Musicians",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/musicians?genre=Afrobeats&instrument=Guitar&location=Lagos&min_exp=3&sort_by=experience",
            "description": "Searches musician profiles by genre, instrument, location, experience, and sorting."
          }
        }
      ]
    },
    {
      "name": "Jobs And Applications",
      "item": [
        {
          "name": "Post Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('job_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{client_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Afrobeats guitar session\",\n  \"description\": \"Need guitar for a studio session\",\n  \"instrument\": \"Guitar\",\n  \"genre\": \"Afrobeats\",\n  \"location\": \"Lagos\",\n  \"budget\": 500\n}"
            },
            "url": "{{base_url}}/jobs",
            "description": "Client creates a job listing."
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/jobs?status=open&genre=Afrobeats&sort_by=budget&max_applications=5",
            "description": "Lists jobs using filters and sorting."
          }
        },
        {
          "name": "Get Job By ID",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/jobs?id={{job_id}}",
            "description": "Fetches one job by ID."

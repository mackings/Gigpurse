# Server-only: base URL of the Go backend. Used by the BFF route handlers and
# the generic authenticated proxy. Never exposed to the client.
GIGPURSE_API_URL=http://localhost:8080

# Public: same backend base URL, exposed to client JS. Used ONLY to open the
# realtime chat WebSocket directly against the Go backend (Next.js Route
# Handlers can't proxy an upgraded WebSocket connection). The JWT itself is
# still fetched narrowly via /api/auth/ws-token, not stored here.
NEXT_PUBLIC_GIGPURSE_API_URL=http://localhost:8080
